{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RustyCalc",
  "version": "0.1.0",
  "identifier": "com.rustycalc.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "trunk serve --public-url /",
    "beforeBuildCommand": "trunk build --release --public-url /"
  },
  "app": {
    "windows": [
      {
        "title": "RustyCalc",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
